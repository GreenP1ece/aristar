{
  "name": "repairman_api",
  "projectType": "application",
  "sourceRoot": "apps/repairman_api",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet build",
        "cwd": "apps/repairman_api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run",
        "cwd": "apps/repairman_api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test",
        "cwd": "apps/repairman_api"
      }
    }
  }
}